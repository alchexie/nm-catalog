{
  "name": "nm-catalog",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c cyan,magenta  \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "pnpm --filter @nm-catalog/backend dev",
    "dev:frontend": "pnpm --filter @nm-catalog/frontend dev",
    "build": "pnpm run clean:dist && pnpm run build:shared && pnpm run build:core && pnpm run build:backend && pnpm run build:frontend && pnpm run build:scripts && pnpm run sync-dist",
    "build:core": "pnpm --filter @nm-catalog/core build",
    "build:shared": "pnpm --filter @nm-catalog/shared build",
    "build:backend": "pnpm --filter @nm-catalog/backend build",
    "build:frontend": "pnpm --filter @nm-catalog/frontend build",
    "build:scripts": "pnpm --filter @nm-catalog/scripts build",
    "sync-dist": "node sync-dist.js",
    "clean:dist": "rimraf --glob \"**/dist\"",
    "clean:deps": "rimraf --glob \"**/node_modules\" pnpm-lock.yaml || true",
    "pull-game": "pnpm --filter @nm-catalog/scripts pull-game",
    "pull-playlist": "pnpm --filter @nm-catalog/scripts pull-playlist",
    "get-img": "pnpm --filter @nm-catalog/scripts get-img",
    "update-latest": "pnpm --filter @nm-catalog/scripts update-latest"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.2",
    "typescript": "~5.8.3"
  }
}
