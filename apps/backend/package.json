{
  "name": "@nm-catalog/backend",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build": "rm -rf dist && tsc",
    "init-db": "pnpm --filter @nm-catalog/core init-db",
    "init-data": "pnpm --filter @nm-catalog/core init-data",
    "modify-db": "pnpm --filter @nm-catalog/core modify-db",
    "update-latest": "pnpm --filter @nm-catalog/core update-latest",
    "pull-game": "pnpm --filter @nm-catalog/core pull-game",
    "pull-playlist": "pnpm --filter @nm-catalog/core pull-playlist",
    "get-img": "pnpm --filter @nm-catalog/core get-img",
    "modify-db:prod": "pnpm --filter @nm-catalog/core modify-db:prod",
    "pull-game:prod": "pnpm --filter @nm-catalog/core pull-game:prod",
    "pull-playlist:prod": "pnpm --filter @nm-catalog/core pull-playlist:prod",
    "get-img:prod": "pnpm --filter @nm-catalog/core get-img:prod"
  },
  "dependencies": {
    "@nm-catalog/core": "workspace:*",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "@nm-catalog/shared": "workspace:*",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "nodemon": "^3.1.10",
    "tsx": "^4.21.0"
  }
}
